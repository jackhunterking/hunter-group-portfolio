# ===== HubSpot =====
# Create a Private App in HubSpot Settings → Integrations → Private Apps
# Scopes needed: crm.objects.contacts.write, crm.objects.contacts.read, crm.schemas.contacts.write
HUBSPOT_ACCESS_TOKEN=pat-na1-xxxxxxxxxxxxxxxxxxxxxxxx

# ===== Resend (for sending the guide via email) =====
# Sign up at resend.com, verify your domain (jackhunter.com), then create an API key
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# The "From" address must be on a domain verified in Resend
RESEND_FROM_EMAIL="Jack Hunter <hello@jackhunter.com>"

# Reply-to address (where prospects can reach you)
RESEND_REPLY_TO=hello@jackhunter.com

# ===== Public site URL =====
# Used for absolute links in the guide email
NEXT_PUBLIC_SITE_URL=https://jackhunter.com
